# ──────────────────────────────────────────────
#  BRO CARS — Environment Variables
#  Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

PORT=3000

# Path to SQLite database file (auto-created)
DB_PATH=./brocars.db

# Admin key — used for all [admin] routes
# Change this to something secret!
ADMIN_KEY=change_me_secret_key

# CORS origin — tighten in production
# ALLOWED_ORIGIN=https://www.brocars.lk

# ── Email (optional — leave blank to skip emails) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
ADMIN_EMAIL=admin@brocars.lk
